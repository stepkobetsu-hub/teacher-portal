const RESPONSE_SS_ID = '1VPTdCQ2_Mws19r0xEPmic4qM65NK-BhLqmgtc-EUFVg';
const RESPONSE_SHEET = 'フォームの回答 1';
const MASTER_SS_ID = '1L5aFDXAmfUDkBg8d7X3WqJgMhdMq5tM5sfUZ2G-M58E';
const MASTER_SHEET = '講師マスター';
function doGet(e){const p=e.parameter||{};const cb=p.callback||'callback';let r;try{if(p.action==='getTeacher')r=getTeacherApi_(p.code);else if(p.action==='submitAttendance')r=submitAttendanceApi_(p);else if(p.action==='saveQrData')r=saveQrDataApi_(p.code,p.qrData);else r={ok:false,message:'actionが不正です。'};}catch(err){r={ok:false,message:err.message||String(err)}}return ContentService.createTextOutput(cb+'('+JSON.stringify(r)+');').setMimeType(ContentService.MimeType.JAVASCRIPT);}
function getTeacherApi_(code){code=String(code||'').trim();if(!code)return{ok:false,message:'講師コードが空です。'};const sh=SpreadsheetApp.openById(MASTER_SS_ID).getSheetByName(MASTER_SHEET);const v=sh.getDataRange().getValues();for(let i=1;i<v.length;i++){if(String(v[i][0]||'').trim()===code){return{ok:true,teacher:{code:code,name:String(v[i][1]||'').trim(),email:String(v[i][15]||'').trim(),qrData:String(v[i][16]||'').trim()}}}}return{ok:false,message:'講師コードが見つかりません。名前がない場合は、すぐに申し出てください。'};}
function submitAttendanceApi_(data){const tr=getTeacherApi_(data.code);if(!tr.ok)throw new Error('講師コードが見つかりません。');const t=tr.teacher;const sh=SpreadsheetApp.openById(RESPONSE_SS_ID).getSheetByName(RESPONSE_SHEET);const koma=data.koma==='その他'?data.komaOther:data.koma;sh.appendRow([new Date(),t.code+' '+t.name,data.workDate,data.lessons,koma,data.memo||'',data.place,t.code]);return{ok:true,name:t.name};}
function saveQrDataApi_(code,qrData){code=String(code||'').trim();qrData=String(qrData||'').trim();if(!code)throw new Error('講師コードが空です。');if(!qrData)throw new Error('QRデータが空です。');const sh=SpreadsheetApp.openById(MASTER_SS_ID).getSheetByName(MASTER_SHEET);const v=sh.getDataRange().getValues();for(let i=1;i<v.length;i++){if(String(v[i][0]||'').trim()===code){sh.getRange(i+1,17).setValue(qrData);return{ok:true,code:code,name:String(v[i][1]||'').trim(),qrData:qrData}}}return{ok:false,message:'講師コードが講師マスターに見つかりません。'};}